{
  "name": "gastown-eval-kit",
  "version": "2.0.0",
  "description": "Gastown automated eval runner - sends Fuel Rod questions to your Copilot agent and generates traces for submission",
  "scripts": {
    "eval": "tsx auto_eval.ts",
    "evals": "tsx auto_eval.ts",
    "validate": "tsx validate_output.ts",
    "clean": "node -e \"['ghcp_eval_traces.json','ghcp_eval_traces.partial.json'].forEach(f=>{try{require('fs').unlinkSync(f)}catch{}})\""
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "openai": "^6.33.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@github/copilot-sdk": "^0.2.0",
    "yaml": "^2.7.0"
  }
}
